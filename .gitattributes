# Ensure shell scripts always use LF line endings, even on Windows
*.sh text eol=lf

# Ensure Python files use LF
*.py text eol=lf

# Docker files
Dockerfile text eol=lf
docker-compose.yml text eol=lf
.dockerignore text eol=lf

# Alembic files
alembic.ini text eol=lf

# Other text files
*.md text eol=lf
*.txt text eol=lf
*.json text eol=lf
*.toml text eol=lf
*.yml text eol=lf
*.yaml text eol=lf

# Environment files
.env* text eol=lf

# Git files
.gitignore text eol=lf
.gitattributes text eol=lf
